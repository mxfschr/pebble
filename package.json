{
  "name": "pebble-memory",
  "version": "0.6.0",
  "description": "Git-native AI memory for Claude Code. Per-project knowledge in your repo, per-user voice machine-local. Open source, local-first, zero LLM API calls.",
  "type": "module",
  "bin": {
    "pebble": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp-server.js"
  },
  "keywords": ["ai", "claude", "memory", "mcp", "coding-assistant", "developer-tools"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
